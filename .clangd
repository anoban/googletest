CompileFlags:
  Add: [-Wall, -Wextra, -pedantic, -O0, -std=c++20, -c, -I./include/, -I./include/gtest/, -DNDEBUG, -D_NDEBUG]
  Compiler:  clang++.exe
  CompilationDatabase: None

Completion:
  AllScopes: Yes

Index:
  Background: Skip
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  BlockEnd: Yes
  Designators: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  TypeNameLimit: 0

Hover:
  ShowAKA: Yes

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None

  ClangTidy:
    FastCheckFilter: None

Style:
  FullyQualifiedNamespaces: Yes
